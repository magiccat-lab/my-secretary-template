# 記入後は権限を絞ってください: chmod 600 .env
# このファイルは plaintext でシークレットを保持します。
# .gitignore で除外済みですが、絶対に commit しないよう注意。
# 漏洩したら docs/bootstrap.md §2（シークレット漏洩時のローテーション）を参照。
#
# このファイルを .env にコピーして値を埋めてください:
#   cp .env.template .env
#   chmod 600 .env
#
# TODO がついている値は必須。オプションのセクションは空でもOK。

# ===== Discord =====
# Bot トークンは ~/.claude/channels/discord/.env に保存します（プラグインが要求）。
# リポジトリのスクリプトもそのファイルから読むので、ここに複製する必要はありません。
# 詳細は SETUP.md セクション D を参照。

DISCORD_USER_ID=                         # TODO: 自分の Discord ユーザーID（定期メッセージのメンション用）

# チャンネルID（Discord → 設定 → 詳細設定 → 開発者モード → チャンネル右クリック → IDをコピー）
DISCORD_CHANNEL_RANDOM=                  # TODO: メインのチャットチャンネル — デイリーリマインドやアドホックなメッセージで必須

# ===== GitHub =====
# ~/secretary の変更（memory, tasks）をバックアップリポジトリに push するのに使う（オプション）。
GITHUB_REPO=                             # 例: yourname/secretary-backup

# ===== Webhook サーバー =====
WEBHOOK_PORT=8781
WEBHOOK_TOKEN=                           # 生成: python3 -c "import secrets; print(secrets.token_hex(32))"

# ===== Google（Calendar + Gmail + Sheets は同じトークンを共有） =====
# integrations/gcal/reauth.py を1回実行して token.json を作ってください。
GOOGLE_TOKEN_PATH=integrations/gcal/token.json
GCAL_CALENDAR_ID=primary                 # または your-calendar@gmail.com

# ===== タスクストレージ（Google Sheets バックエンド、オプション） =====
# 空にするとローカル JSON（デフォルト）を使用。セットすると双方向同期が有効になる。
TASK_SHEET_ID=

# ===== フィーチャーフラグ =====
GMAIL_ENABLED=false
GCAL_REMIND_ENABLED=true

# ===== オプションの API =====
BRAVE_API_KEY=                           # Brave Search（リサーチ・Web検索用）
